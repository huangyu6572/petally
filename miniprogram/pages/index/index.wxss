/* pages/index/index.wxss */
.container {
  padding: 0 0 120rpx;
  background: #f8f8f8;
  min-height: 100vh;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 32rpx 40rpx;
  background: linear-gradient(135deg, #FF69B4, #FFB6C1);
}

.logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
}

.welcome {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
}

.features {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  padding: 40rpx 24rpx;
  background: #fff;
  margin: 20rpx 24rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.feature-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 200rpx;
  padding: 20rpx 10rpx;
}

.feature-icon {
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 16rpx;
}

.feature-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.feature-desc {
  font-size: 22rpx;
  color: #999;
  text-align: center;
}

.section {
  background: #fff;
  margin: 20rpx 24rpx;
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  display: block;
}

.promo-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.promo-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.promo-info {
  flex: 1;
}

.promo-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
  display: block;
}

.promo-price {
  font-size: 30rpx;
  color: #FF69B4;
  font-weight: bold;
}

.empty-tip {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 28rpx;
}
