/* pages/promotion/detail/index.wxss */
.container {
  padding-bottom: 160rpx;
  background: #f8f8f8;
  min-height: 100vh;
}

.main-img {
  width: 100%;
  height: 650rpx;
}

.price-bar {
  background: linear-gradient(90deg, #FF69B4, #FFB6C1);
  padding: 28rpx 32rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.price-now {
  font-size: 52rpx;
  font-weight: bold;
  color: #fff;
  margin-right: 16rpx;
}

.price-original {
  font-size: 28rpx;
  color: rgba(255,255,255,0.65);
  text-decoration: line-through;
}

.discount-badge {
  background: rgba(255,255,255,0.25);
  border-radius: 8rpx;
  padding: 8rpx 20rpx;
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
}

.info-block {
  background: #fff;
  padding: 32rpx;
  margin-bottom: 16rpx;
}

.brand-tag {
  font-size: 24rpx;
  color: #FF69B4;
  background: #fff5f8;
  border-radius: 6rpx;
  padding: 4rpx 16rpx;
  margin-bottom: 16rpx;
  display: inline-block;
}

.product-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.4;
  margin-bottom: 20rpx;
  display: block;
}

.product-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}

.coupon-block {
  background: #fff;
  padding: 32rpx;
  margin-bottom: 16rpx;
}

.coupon-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.coupon-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.coupon-amount {
  font-size: 36rpx;
  font-weight: bold;
  color: #FF69B4;
}

.coupon-rule {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 24rpx;
  display: block;
}

.btn-coupon {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: #fff5f8;
  color: #FF69B4;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 40rpx;
  border: 2rpx solid #FF69B4;
}

.btn-coupon[disabled] {
  background: #f5f5f5;
  color: #bbb;
  border-color: #e8e8e8;
}

.meta-block {
  background: #fff;
  padding: 24rpx 32rpx;
  margin-bottom: 16rpx;
}

.meta-item {
  font-size: 24rpx;
  color: #999;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  flex-direction: row;
  padding: 20rpx 32rpx;
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
  gap: 20rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.btn-share {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background: #fff;
  color: #FF69B4;
  font-size: 30rpx;
  border-radius: 44rpx;
  border: 2rpx solid #FF69B4;
}

.btn-buy {
  flex: 2;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(90deg, #FF69B4, #FF8DC7);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 5rpx solid #f0f0f0;
  border-top-color: #FF69B4;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }
