<!-- pages/promotion/list/index.wxml -->
<view class="container">
  <!-- 分类筛选 -->
  <scroll-view class="category-bar" scroll-x="true">
    <view class="cat-item {{category === '' ? 'active' : ''}}" bindtap="setCategory" data-cat="">全部</view>
    <view class="cat-item {{category === item ? 'active' : ''}}"
          wx:for="{{categories}}" wx:key="*this"
          bindtap="setCategory" data-cat="{{item}}">{{item}}</view>
  </scroll-view>

  <!-- 商品列表 -->
  <view wx:if="{{loading && list.length === 0}}" class="loading-wrap">
    <view class="loading-spinner" />
  </view>

  <view wx:elif="{{list.length > 0}}" class="grid">
    <view class="promo-card" wx:for="{{list}}" wx:key="id"
          bindtap="goToDetail" data-id="{{item.id}}">
      <image src="{{item.image_url || '/assets/icons/placeholder.png'}}" mode="aspectFill" class="card-img" />
      <view class="card-body">
        <text class="card-brand">{{item.brand}}</text>
        <text class="card-name">{{item.product_name}}</text>
        <view class="price-row">
          <text class="price-now">¥{{item.discounted_price}}</text>
          <text class="price-original" wx:if="{{item.original_price}}">¥{{item.original_price}}</text>
        </view>
        <view class="coupon-tag" wx:if="{{item.coupon_available}}">
          <text>有优惠券</text>
        </view>
      </view>
    </view>
  </view>

  <view wx:elif="{{!loading}}" class="empty-wrap">
    <text class="empty-icon">🛍️</text>
    <text class="empty-text">暂无推荐商品</text>
  </view>

  <view class="load-more" wx:if="{{hasMore && list.length > 0}}" bindtap="loadMore">
    <text>{{loadingMore ? '加载中...' : '加载更多'}}</text>
  </view>
</view>
