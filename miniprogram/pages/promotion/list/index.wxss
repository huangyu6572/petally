/* pages/promotion/list/index.wxss */
.container {
  padding: 0 0 120rpx;
  background: #f8f8f8;
  min-height: 100vh;
}

.category-bar {
  background: #fff;
  white-space: nowrap;
  padding: 16rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 16rpx;
}

.cat-item {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  font-size: 26rpx;
  color: #555;
  border-radius: 30rpx;
  border: 2rpx solid #e8e8e8;
  background: #fff;
}

.cat-item.active {
  background: #FF69B4;
  border-color: #FF69B4;
  color: #fff;
  font-weight: 600;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 80rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 5rpx solid #f0f0f0;
  border-top-color: #FF69B4;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

.grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  padding: 0 16rpx;
  gap: 16rpx;
}

.promo-card {
  width: calc(50% - 8rpx);
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.07);
}

.card-img {
  width: 100%;
  height: 320rpx;
}

.card-body {
  padding: 20rpx;
}

.card-brand {
  font-size: 22rpx;
  color: #FF69B4;
  margin-bottom: 6rpx;
  display: block;
}

.card-name {
  font-size: 26rpx;
  color: #333;
  font-weight: 600;
  line-height: 1.4;
  margin-bottom: 12rpx;
  display: block;
  /* 2行省略 */
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.price-row {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  margin-bottom: 8rpx;
}

.price-now {
  font-size: 32rpx;
  font-weight: bold;
  color: #FF69B4;
  margin-right: 10rpx;
}

.price-original {
  font-size: 22rpx;
  color: #bbb;
  text-decoration: line-through;
}

.coupon-tag {
  display: inline-block;
  background: #fff5f8;
  border: 1rpx solid #FF69B4;
  color: #FF69B4;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 28rpx; color: #999; }

.load-more {
  text-align: center;
  padding: 32rpx;
  font-size: 26rpx;
  color: #999;
}
