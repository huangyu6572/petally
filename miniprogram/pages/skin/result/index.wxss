/* pages/skin/result/index.wxss */
.container {
  padding: 32rpx 32rpx 120rpx;
  background: #f8f8f8;
  min-height: 100vh;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
  color: #999;
  font-size: 28rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 5rpx solid #f0f0f0;
  border-top-color: #FF69B4;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin { to { transform: rotate(360deg); } }

.score-card {
  background: linear-gradient(135deg, #FF69B4, #FFB6C1);
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 30rpx rgba(255, 105, 180, 0.35);
}

.score-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-right: 40rpx;
  flex-shrink: 0;
}

.score-num {
  font-size: 60rpx;
  font-weight: bold;
  color: #fff;
  line-height: 1;
}

.score-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.85);
  margin-top: 8rpx;
}

.score-info {
  flex: 1;
}

.pet-type {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
  margin-bottom: 12rpx;
  display: block;
}

.analysis-time {
  font-size: 22rpx;
  color: rgba(255,255,255,0.75);
}

.section-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  display: block;
}

.issue-item {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.issue-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  margin-top: 8rpx;
  flex-shrink: 0;
}

.issue-dot.severity-high { background: #e74c3c; }
.issue-dot.severity-medium { background: #f39c12; }
.issue-dot.severity-low { background: #2ecc71; }

.issue-content {
  flex: 1;
}

.issue-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
  display: block;
}

.issue-desc {
  font-size: 24rpx;
  color: #888;
  line-height: 1.5;
}

.issue-severity {
  font-size: 22rpx;
  color: #999;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.suggestion-item {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  padding: 10rpx 0;
}

.suggestion-icon {
  font-size: 30rpx;
  color: #FF69B4;
  margin-right: 16rpx;
  line-height: 1.5;
}

.suggestion-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.7;
  flex: 1;
}

.promo-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.promo-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.promo-info { flex: 1; }

.promo-name {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 8rpx;
  display: block;
}

.promo-price {
  font-size: 28rpx;
  color: #FF69B4;
  font-weight: bold;
}

.arrow {
  font-size: 40rpx;
  color: #ccc;
  margin-left: 10rpx;
}

.actions {
  margin-top: 16rpx;
}

.btn-primary {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(90deg, #FF69B4, #FF8DC7);
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255, 105, 180, 0.35);
  margin-bottom: 20rpx;
}

.btn-secondary {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #fff;
  color: #FF69B4;
  font-size: 30rpx;
  border-radius: 44rpx;
  border: 2rpx solid #FF69B4;
}
