/* pages/skin/capture/index.wxss */
.container {
  padding: 32rpx 32rpx 120rpx;
  background: #f8f8f8;
  min-height: 100vh;
}

.header-tips {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.tips-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
  display: block;
}

.tips-desc {
  font-size: 26rpx;
  color: #999;
  line-height: 1.6;
}

.preview-area {
  width: 100%;
  height: 500rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-img {
  width: 100%;
  height: 100%;
}

.placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.placeholder-text {
  font-size: 28rpx;
  color: #bbb;
}

.type-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.type-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.type-list {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
}

.type-item {
  padding: 12rpx 30rpx;
  border-radius: 30rpx;
  border: 2rpx solid #ddd;
  font-size: 26rpx;
  color: #555;
}

.type-item.selected {
  border-color: #FF69B4;
  color: #FF69B4;
  background: #fff5f8;
}

.btn-primary {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(90deg, #FF69B4, #FF8DC7);
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255, 105, 180, 0.35);
  margin-bottom: 20rpx;
}

.btn-primary[disabled] {
  background: #ddd;
  box-shadow: none;
}

.btn-secondary {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #fff;
  color: #FF69B4;
  font-size: 30rpx;
  border-radius: 44rpx;
  border: 2rpx solid #FF69B4;
}
