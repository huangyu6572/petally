<!-- pages/skin/history/index.wxml -->
<view class="container">
  <view class="tab-bar">
    <text class="tab-item {{activeTab === 'list' ? 'active' : ''}}" bindtap="switchTab" data-tab="list">历史记录</text>
    <text class="tab-item {{activeTab === 'trend' ? 'active' : ''}}" bindtap="switchTab" data-tab="trend">趋势变化</text>
  </view>

  <block wx:if="{{activeTab === 'list'}}">
    <view wx:if="{{loading && list.length === 0}}" class="loading-wrap">
      <view class="loading-spinner" />
    </view>
    <view wx:elif="{{list.length > 0}}" class="list">
      <view class="history-item" wx:for="{{list}}" wx:key="id"
            bindtap="goToResult" data-id="{{item.id}}">
        <view class="item-score-wrap">
          <text class="item-score">{{item.overall_score}}</text>
          <text class="item-score-label">分</text>
        </view>
        <view class="item-info">
          <text class="item-type">{{item.analysis_type}}</text>
          <text class="item-time">{{item.created_at}}</text>
          <text class="item-issues">发现 {{item.issues_count || 0}} 个问题</text>
        </view>
        <text class="arrow">›</text>
      </view>
    </view>
    <view wx:elif="{{!loading}}" class="empty-wrap">
      <text class="empty-icon">📋</text>
      <text class="empty-text">暂无分析记录</text>
    </view>
  </block>

  <block wx:elif="{{activeTab === 'trend'}}">
    <view class="trend-placeholder">
      <text class="placeholder-text">趋势图功能即将上线</text>
      <text class="placeholder-sub">查看肌肤健康变化趋势</text>
    </view>
  </block>
</view>
