/* pages/skin/history/index.wxss */
.container {
  padding: 0 0 120rpx;
  background: #f8f8f8;
  min-height: 100vh;
}

.tab-bar {
  display: flex;
  flex-direction: row;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 16rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 28rpx;
  color: #999;
  position: relative;
}

.tab-item.active {
  color: #FF69B4;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 25%;
  width: 50%;
  height: 4rpx;
  background: #FF69B4;
  border-radius: 2rpx;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 5rpx solid #f0f0f0;
  border-top-color: #FF69B4;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

.list {
  background: #fff;
  margin: 0 24rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.history-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.item-score-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF69B4, #FFB6C1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 28rpx;
  flex-shrink: 0;
  flex-direction: row;
}

.item-score {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.item-score-label {
  font-size: 20rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 6rpx;
}

.item-info { flex: 1; }

.item-type {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
  display: block;
}

.item-time, .item-issues {
  font-size: 22rpx;
  color: #aaa;
  display: block;
  margin-bottom: 4rpx;
}

.arrow {
  font-size: 40rpx;
  color: #ccc;
}

.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.trend-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.placeholder-text {
  font-size: 32rpx;
  color: #555;
  margin-bottom: 16rpx;
}

.placeholder-sub {
  font-size: 26rpx;
  color: #aaa;
}
