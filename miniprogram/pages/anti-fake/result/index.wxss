/* pages/anti-fake/result/index.wxss */
.container {
  padding: 32rpx;
  background: #f8f8f8;
  min-height: 100vh;
}

.loading-wrap, .error-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #f0f0f0;
  border-top-color: #FF69B4;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin { to { transform: rotate(360deg); } }

.loading-text, .error-text {
  font-size: 28rpx;
  color: #999;
  margin-top: 16rpx;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.status-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 32rpx;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
}

.status-card.authentic {
  background: linear-gradient(135deg, #e8f9f0, #c6f0d8);
}

.status-card.fake {
  background: linear-gradient(135deg, #fff0f0, #ffd0d0);
}

.status-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.status-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.confidence {
  font-size: 26rpx;
  color: #666;
}

.info-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  display: block;
}

.info-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-label {
  font-size: 26rpx;
  color: #999;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  max-width: 60%;
  text-align: right;
}

.detail-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.8;
}

.actions {
  margin-top: 16rpx;
}

.btn-primary {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(90deg, #FF69B4, #FF8DC7);
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255, 105, 180, 0.35);
  margin-bottom: 20rpx;
}

.btn-secondary {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #fff;
  color: #FF69B4;
  font-size: 30rpx;
  border-radius: 44rpx;
  border: 2rpx solid #FF69B4;
}
