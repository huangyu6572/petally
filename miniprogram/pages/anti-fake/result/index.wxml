<!-- pages/anti-fake/result/index.wxml -->
<view class="container">
  <view wx:if="{{loading}}" class="loading-wrap">
    <view class="loading-spinner" />
    <text class="loading-text">加载中...</text>
  </view>

  <block wx:elif="{{result}}">
    <!-- 结果状态卡片 -->
    <view class="status-card {{result.is_authentic ? 'authentic' : 'fake'}}">
      <text class="status-icon">{{result.is_authentic ? '✅' : '❌'}}</text>
      <text class="status-text">{{result.is_authentic ? '正品验证通过' : '疑似假冒产品'}}</text>
      <text class="confidence">可信度 {{result.confidence_score}}%</text>
    </view>

    <!-- 产品信息 -->
    <view class="info-card" wx:if="{{result.product_info}}">
      <text class="card-title">产品信息</text>
      <view class="info-row">
        <text class="info-label">品牌</text>
        <text class="info-value">{{result.product_info.brand || '—'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">产品名称</text>
        <text class="info-value">{{result.product_info.name || '—'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">序列号</text>
        <text class="info-value">{{result.serial_number || '—'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">查询次数</text>
        <text class="info-value">{{result.query_count}} 次</text>
      </view>
    </view>

    <!-- 检测详情 -->
    <view class="info-card" wx:if="{{result.details}}">
      <text class="card-title">检测详情</text>
      <text class="detail-text">{{result.details}}</text>
    </view>

    <!-- 操作按钮 -->
    <view class="actions">
      <button class="btn-primary" bindtap="scanAgain">再次扫码</button>
      <button class="btn-secondary" bindtap="goToHistory">查看历史</button>
    </view>
  </block>

  <view wx:elif="{{error}}" class="error-wrap">
    <text class="error-icon">⚠️</text>
    <text class="error-text">{{error}}</text>
    <button class="btn-primary" bindtap="scanAgain">重新扫码</button>
  </view>
</view>
