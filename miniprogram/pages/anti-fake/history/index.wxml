<!-- pages/anti-fake/history/index.wxml -->
<!-- v2: 条形码查询 + 品牌跳转历史 -->
<view class="container">
  <view wx:if="{{loading && list.length === 0}}" class="loading-wrap">
    <view class="loading-spinner" />
    <text>加载中...</text>
  </view>

  <block wx:elif="{{list.length > 0}}">
    <view class="list">
      <view class="history-item" wx:for="{{list}}" wx:key="index">
        <view class="item-left">
          <text class="item-type {{item.query_type === 'barcode' ? 'type-barcode' : 'type-brand'}}">
            {{item.query_type === 'barcode' ? '📷 条形码' : '🏷️ 品牌验证'}}
          </text>
          <text class="item-value">{{item.query_value}}</text>
          <text class="item-product" wx:if="{{item.product_name}}">{{item.product_name}}</text>
          <text class="item-brand" wx:if="{{item.brand_name}}">{{item.brand_name}}</text>
          <text class="item-summary">{{item.result_summary}}</text>
          <text class="item-time">{{item.queried_at}}</text>
        </view>
      </view>
    </view>

    <view class="load-more" wx:if="{{hasMore}}" bindtap="loadMore">
      <text>{{loadingMore ? '加载中...' : '加载更多'}}</text>
    </view>
    <view class="no-more" wx:else>
      <text>— 已加载全部 —</text>
    </view>
  </block>

  <view wx:elif="{{!loading}}" class="empty-wrap">
    <text class="empty-icon">🔍</text>
    <text class="empty-text">暂无查询记录</text>
    <button class="btn-primary" bindtap="goToScan">去查询</button>
  </view>
</view>
