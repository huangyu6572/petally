<!-- pages/anti-fake/history/index.wxml -->
<view class="container">
  <view wx:if="{{loading && list.length === 0}}" class="loading-wrap">
    <view class="loading-spinner" />
    <text>加载中...</text>
  </view>

  <block wx:elif="{{list.length > 0}}">
    <view class="list">
      <view class="history-item" wx:for="{{list}}" wx:key="id"
            bindtap="goToResult" data-id="{{item.id}}">
        <view class="item-left">
          <text class="item-status {{item.is_authentic ? 'authentic' : 'fake'}}">
            {{item.is_authentic ? '✅ 正品' : '❌ 假冒'}}
          </text>
          <text class="item-code">{{item.serial_number || item.code}}</text>
          <text class="item-time">{{item.created_at}}</text>
        </view>
        <text class="arrow">›</text>
      </view>
    </view>

    <view class="load-more" wx:if="{{hasMore}}" bindtap="loadMore">
      <text>{{loadingMore ? '加载中...' : '加载更多'}}</text>
    </view>
    <view class="no-more" wx:else>
      <text>— 已加载全部 —</text>
    </view>
  </block>

  <view wx:elif="{{!loading}}" class="empty-wrap">
    <text class="empty-icon">🔍</text>
    <text class="empty-text">暂无查询记录</text>
    <button class="btn-primary" bindtap="goToScan">去扫码查询</button>
  </view>
</view>
