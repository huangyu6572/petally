/* pages/anti-fake/history/index.wxss */
.container {
  padding: 24rpx 32rpx 120rpx;
  background: #f8f8f8;
  min-height: 100vh;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
  color: #999;
  font-size: 28rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 5rpx solid #f0f0f0;
  border-top-color: #FF69B4;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin { to { transform: rotate(360deg); } }

.list {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.history-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.item-left {
  display: flex;
  flex-direction: column;
}

.item-status {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.item-status.authentic { color: #2ecc71; }
.item-status.fake { color: #e74c3c; }

.item-code {
  font-size: 24rpx;
  color: #555;
  margin-bottom: 6rpx;
}

.item-time {
  font-size: 22rpx;
  color: #bbb;
}

.arrow {
  font-size: 40rpx;
  color: #ccc;
}

.load-more, .no-more {
  text-align: center;
  padding: 32rpx;
  font-size: 26rpx;
  color: #999;
}

.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 32rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 48rpx;
}

.btn-primary {
  width: 400rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(90deg, #FF69B4, #FF8DC7);
  color: #fff;
  font-size: 30rpx;
  border-radius: 44rpx;
  border: none;
}
