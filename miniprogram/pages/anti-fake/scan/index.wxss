/* pages/anti-fake/scan/index.wxss */
.container {
  padding: 40rpx 32rpx 120rpx;
  background: #f8f8f8;
  min-height: 100vh;
}

.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 32rpx;
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.hero-img {
  width: 220rpx;
  height: 220rpx;
  margin-bottom: 32rpx;
  opacity: 0.85;
}

.hero-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.hero-desc {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  line-height: 1.6;
}

.actions {
  margin-bottom: 32rpx;
}

.btn-primary {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(90deg, #FF69B4, #FF8DC7);
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255, 105, 180, 0.35);
  margin-bottom: 20rpx;
}

.btn-secondary {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #fff;
  color: #FF69B4;
  font-size: 30rpx;
  border-radius: 44rpx;
  border: 2rpx solid #FF69B4;
}

.tips {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.tips-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.tip-item {
  font-size: 26rpx;
  color: #666;
  line-height: 2;
  display: block;
}
