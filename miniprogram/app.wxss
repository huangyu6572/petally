/* Petal 全局样式 */
page {
  background-color: #FFF0F5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  color: #333;
}

.container {
  padding: 30rpx;
}

/* 主题色 */
.text-primary { color: #FF69B4; }
.bg-primary { background-color: #FF69B4; }

.btn-primary {
  background-color: #FF69B4;
  color: #fff;
  border-radius: 40rpx;
  padding: 20rpx 60rpx;
  font-size: 32rpx;
  border: none;
}

.btn-primary:active {
  background-color: #FF1493;
}

.card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}
