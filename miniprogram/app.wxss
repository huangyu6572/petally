/* Petal 全局样式 */
page {
  background-color: #FFF0F5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  color: #333;
}

.container {
  padding: 30rpx;
}

/* 主题色 */
.text-primary { color: #FF69B4; }
.bg-primary { background-color: #FF69B4; }

.btn-primary {
  background-color: #FF69B4;
  color: #fff;
  border-radius: 40rpx;
  padding: 20rpx 60rpx;
  font-size: 32rpx;
  border: none;
}

.btn-primary:active {
  background-color: #FF1493;
}

.card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

/* 通用工具类 */
.flex-row { display: flex; flex-direction: row; align-items: center; }
.flex-col { display: flex; flex-direction: column; }
.flex-center { align-items: center; justify-content: center; }
.flex-1 { flex: 1; }

.text-center { text-align: center; }
.text-muted { color: #999; }
.text-bold { font-weight: bold; }
.text-sm { font-size: 24rpx; }
.text-lg { font-size: 34rpx; }

.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-32 { margin-top: 32rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-24 { margin-bottom: 24rpx; }
.mb-32 { margin-bottom: 32rpx; }
.p-32 { padding: 32rpx; }

/* 通用加载态 */
.page-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #999;
  font-size: 26rpx;
}

/* 安全区底部 */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
